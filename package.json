{
  "name": "bun-api",
  "version": "1.0.0",
  "module": "src/index.js",
  "scripts": {
    "dev": "bun run --watch src/app/index.ts",
    "build": "bun build --minify-whitespace --minify-syntax --target bun --outfile ./dist/index.js src/index.ts",
    "start": "bun run ./dist/index.js",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "migration:generate": "drizzle-kit generate --config ./drizzle.config.ts",
    "migration:run": "drizzle-kit push --config ./drizzle.config.ts"
  },
  "dependencies": {
    "@tursodatabase/database": "^0.5.3",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^1.0.0-beta.22",
    "elysia": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "bun-types": "latest",
    "drizzle-kit": "^1.0.0-beta.22"
  }
}
