{
  "name": "bun-api",
  "version": "1.0.0",
  "module": "src/index.js",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build --minify-whitespace --minify-syntax --outfile ./dist/index.js src/index.ts",
    "start": "bun run ./dist/index.js",
    "lint": "biome lint --write",
    "format": "biome format --write"
  },
  "dependencies": {
    "@tursodatabase/database": "^0.5.3",
    "elysia": "latest"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "bun-types": "latest"
  }
}
